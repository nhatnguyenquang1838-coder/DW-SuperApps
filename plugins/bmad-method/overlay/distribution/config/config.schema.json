{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dw.superapps/schemas/bmad-config.schema.json",
  "title": "BMAD Power Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "module",
    "host"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "module": {
      "type": "string",
      "enum": [
        "bmm"
      ]
    },
    "host": {
      "type": "string",
      "enum": [
        "kiro",
        "codex",
        "copilot",
        "cline",
        "kilo",
        "claude",
        "custom"
      ]
    },
    "userName": {
      "type": "string",
      "minLength": 1
    },
    "communicationLanguage": {
      "type": "string",
      "minLength": 1
    },
    "documentOutputLanguage": {
      "type": "string",
      "minLength": 1
    },
    "outputFolder": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|/)\\.\\.(/|$)"
      }
    },
    "projectKnowledge": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|/)\\.\\.(/|$)"
      }
    }
  }
}
