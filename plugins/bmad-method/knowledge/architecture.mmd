flowchart LR
  H["bmad-help<br/>workflow router"]:::primary
  B["Brainstorming"]:::analysis
  PB["Product Brief"]:::analysis
  PRD["PRD"]:::planning
  UX["UX Design"]:::planning
  ARCH["Architecture"]:::solution
  ES["Epics & Stories"]:::solution
  SP["Sprint Planning"]:::implementation
  CS["Create Story"]:::implementation
  DEV["Dev Story"]:::implementation
  CR["Code Review"]:::quality
  QD["Quick Dev"]:::implementation
  CLI["BMAD CLI / Installer"]:::installer
  CORE["Core Skills"]:::module
  BMM["BMM Skills"]:::module
  DIST["DW BMAD Publisher"]:::primary
  DOCS["Website / Docs / Evals<br/>excluded from package"]:::excluded

  H --> B --> PB --> PRD
  PRD -. optional .-> UX
  PRD --> ARCH --> ES --> SP --> CS --> DEV --> CR
  H -. bounded path .-> QD --> CR

  CLI --> CORE
  CLI --> BMM
  CORE --> H
  BMM --> PB
  BMM --> PRD
  BMM --> ARCH
  BMM --> SP

  DIST -->|allowlist| CORE
  DIST -->|allowlist| BMM
  DIST -->|bootstrap dependency| CLI
  DIST -. rejects .-> DOCS

