#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
DW SuperApps workspace command

Usage:
  bin/dw validate
  bin/dw power <init|check|update|pin|status> [target]
  bin/dw host install
  bin/dw system list

Examples:
  bin/dw power check
  bin/dw power update task-me
  bin/dw power pin powers
  bin/dw validate
EOF
}

command="${1:-help}"
shift || true

case "$command" in
  validate)
    exec python3 "$ROOT/scripts/validate-workspace.py" "$@"
    ;;
  power)
    mode="${1:-check}"
    target="${2:-all}"
    exec bash "$ROOT/scripts/sync-submodules.sh" "$mode" "$target"
    ;;
  host)
    subcommand="${1:-install}"
    [[ "$subcommand" == "install" ]] || { usage; exit 2; }
    exec bash "$ROOT/scripts/install-host-adapters.sh"
    ;;
  system)
    subcommand="${1:-list}"
    [[ "$subcommand" == "list" ]] || { usage; exit 2; }
    python3 - "$ROOT/workspace.yaml" <<'PY'
import sys
try:
    import yaml
except ImportError:
    print("Missing PyYAML. Run: python -m pip install -r requirements-dev.txt", file=sys.stderr)
    raise SystemExit(2)
with open(sys.argv[1], encoding="utf-8") as stream:
    workspace = yaml.safe_load(stream)
for system in workspace.get("systems", []):
    powers = ", ".join(system.get("enabled_powers", []))
    print(f"{system['id']}: {system['path']} [{powers}]")
PY
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
