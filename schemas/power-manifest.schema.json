{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dw-superapps.local/schemas/power-manifest.schema.json",
  "title": "DW SuperApps Power Manifest v2",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "dw.superapps/v2"
    },
    "kind": {
      "const": "Power"
    },
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": [
        "category",
        "path",
        "source",
        "provides",
        "consumes",
        "runtimeDataRoot",
        "hosts",
        "entrypoints",
        "permissions"
      ],
      "properties": {
        "category": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "pattern": "^powers/[a-z0-9][a-z0-9-]*$"
        },
        "source": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "provides": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "consumes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "optionalIntegrations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "runtimeDataRoot": {
          "type": "string",
          "pattern": "^\\.[a-z0-9][a-z0-9._-]*$"
        },
        "hosts": {
          "type": "array",
          "items": {
            "enum": [
              "kiro",
              "codex",
              "copilot",
              "cline",
              "kilo",
              "claude",
              "custom",
              "cli"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "entrypoints": {
          "type": "object",
          "required": [
            "skillCandidates"
          ],
          "properties": {
            "skillCandidates": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "cliCandidates": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "permissions": {
          "type": "object",
          "required": [
            "read",
            "write",
            "deny"
          ],
          "properties": {
            "read": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "write": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "deny": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
