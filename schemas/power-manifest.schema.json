{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dw-superapps.local/schemas/power-manifest.schema.json",
  "title": "DW SuperApps Power Manifest v2",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "dw.superapps/v2"
    },
    "kind": {
      "const": "Power"
    },
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": [
        "category",
        "path",
        "source",
        "provides",
        "consumes",
        "runtimeDataRoot",
        "hosts",
        "entrypoints",
        "permissions"
      ],
      "properties": {
        "category": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "pattern": "^powers/[a-z0-9][a-z0-9-]*$"
        },
        "source": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "provides": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "consumes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "optionalIntegrations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "runtimeDataRoot": {
          "type": "string",
          "pattern": "^\\.[a-z0-9][a-z0-9._-]*$"
        },
        "hosts": {
          "type": "array",
          "items": {
            "enum": [
              "kiro",
              "codex",
              "copilot",
              "cline",
              "kilo",
              "claude",
              "custom",
              "cli"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "entrypoints": {
          "type": "object",
          "required": [
            "skillCandidates"
          ],
          "properties": {
            "skillCandidates": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "cliCandidates": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "permissions": {
          "type": "object",
          "required": [
            "read",
            "write",
            "deny"
          ],
          "properties": {
            "read": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "write": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "deny": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "distribution": {
          "type": "object",
          "required": [
            "contract",
            "defaultMode",
            "modes",
            "providerState"
          ],
          "properties": {
            "contract": {
              "const": "dw.power-distribution/v1"
            },
            "defaultMode": {
              "enum": [
                "submodule",
                "release",
                "power-dist"
              ]
            },
            "modes": {
              "type": "object",
              "required": [
                "submodule",
                "release",
                "powerDist"
              ],
              "properties": {
                "submodule": {
                  "type": "object",
                  "required": [
                    "repository",
                    "path",
                    "ref"
                  ],
                  "properties": {
                    "repository": {
                      "type": "string",
                      "pattern": "^[^/\\s]+/[^/\\s]+$"
                    },
                    "path": {
                      "type": "string",
                      "pattern": "^powers/[a-z0-9][a-z0-9-]*$"
                    },
                    "ref": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                },
                "release": {
                  "type": "object",
                  "required": [
                    "repository",
                    "assetPattern",
                    "checksumAssetPattern"
                  ],
                  "properties": {
                    "repository": {
                      "type": "string",
                      "pattern": "^[^/\\s]+/[^/\\s]+$"
                    },
                    "assetPattern": {
                      "type": "string",
                      "minLength": 1
                    },
                    "checksumAssetPattern": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                },
                "powerDist": {
                  "type": "object",
                  "required": [
                    "repository",
                    "ref"
                  ],
                  "properties": {
                    "repository": {
                      "type": "string",
                      "pattern": "^[^/\\s]+/[^/\\s]+$"
                    },
                    "ref": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "providerState": {
              "type": "object",
              "required": [
                "status",
                "task"
              ],
              "properties": {
                "status": {
                  "enum": [
                    "ready-unpublished",
                    "published",
                    "blocked-policy",
                    "blocked-missing-repository"
                  ]
                },
                "task": {
                  "type": "string",
                  "pattern": "^DW-PDIST-[0-9]{2}$"
                },
                "sourceCommit": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "pattern": "^[0-9a-f]{40}$"
                },
                "sourceLock": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "minLength": 1
                },
                "note": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
