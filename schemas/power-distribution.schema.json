{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dw.superapps/schemas/power-distribution.schema.json",
  "title": "DW Power Distribution Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "dw.superapps/v1"},
    "kind": {"const": "PowerDistribution"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "package", "include", "runtime"],
      "properties": {
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$"},
            "defaultRef": {"type": "string", "default": "main"}
          }
        },
        "package": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entrypoints"],
          "properties": {
            "entrypoints": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/relativePath"}
            },
            "managedPaths": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/relativePath"}
            },
            "runtimeTemplates": {"type": "boolean", "default": true}
          }
        },
        "include": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/relativePattern"}
        },
        "exclude": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/relativePattern"}
        },
        "forbidden": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "paths": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/relativePattern"}
            },
            "contentPatterns": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dataRoot"],
          "properties": {
            "dataRoot": {"$ref": "#/$defs/relativePath"},
            "configRequired": {"type": "boolean", "default": false}
          }
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {"pattern": "^/"},
          {"pattern": "^[A-Za-z]:[\\\\/]"},
          {"pattern": "(^|/)\\.\\.(/|$)"},
          {"pattern": "\\u0000"}
        ]
      }
    },
    "relativePattern": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {"pattern": "^/"},
          {"pattern": "^[A-Za-z]:[\\\\/]"},
          {"pattern": "(^|/)\\.\\.(/|$)"},
          {"pattern": "\\u0000"}
        ]
      }
    }
  }
}
