{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dw.superapps/schemas/power-consumer-binding.schema.json",
  "title": "DW Power Consumer Binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "dw.superapps/v1"},
    "kind": {"const": "PowerConsumerBinding"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["powerId"],
      "properties": {
        "powerId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"},
        "consumerId": {"type": "string", "minLength": 1}
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hosts", "permissions"],
      "properties": {
        "hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["kiro", "codex", "copilot", "cline", "kilo", "claude", "custom", "cli"]
          }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["read", "write", "deny"],
          "properties": {
            "read": {"type": "array", "items": {"type": "string"}},
            "write": {"type": "array", "items": {"type": "string"}},
            "deny": {"type": "array", "items": {"type": "string"}}
          }
        },
        "integrations": {
          "type": "object",
          "additionalProperties": {"type": "boolean"}
        },
        "allowNetwork": {"type": "boolean", "default": false},
        "allowExternalWrites": {"type": "boolean", "default": false}
      }
    }
  }
}
